# FastAPI
APP_ENV=production
PROJECT_NAME=Dasan Shift Manager
DATABASE_URL=postgresql+psycopg2://worktime:change_me@127.0.0.1:5432/work_time
JWT_SECRET=replace_with_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
API_ROOT_PATH=
TRUSTED_HOSTS=localhost,127.0.0.1,*.trycloudflare.com,*.cfargotunnel.com,*.workers.dev
TRUST_ALL_HOSTS=false
BACKEND_CORS_ORIGINS=
BACKEND_CORS_ALLOW_CREDENTIALS=false

# Backup storage and data management
# The directory must exist and be writable by the FastAPI service user.
BACKUP_STORAGE_DIR=/srv/app/backups
BACKUP_UPLOAD_MAX_BYTES=10485760
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_FILES_PER_DOMAIN=50

# Optional bootstrap account
MASTER_LOGIN_ID=master
MASTER_PASSWORD=change_me_now
MASTER_NAME=Master Admin
MASTER_IDENTIFIER=MASTER_DEFAULT

# Cloudflare Quick Tunnel updater
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_KV_NAMESPACE_ID=
KV_KEY=active_url
KV_UPDATED_AT_KEY=active_url_updated_at
KV_CLEANUP_KEYS=active_url,ACTIVE_URL
LOCAL_URL=http://127.0.0.1:8080
TUNNEL_HOST_FILTER=trycloudflare.com,cfargotunnel.com
TUNNEL_HOST_DENY=api.trycloudflare.com
SANITIZE_EXISTING_KV=false
CLEAR_KV_ON_429=false
RATE_LIMIT_COOLDOWN_SECONDS=300
NORMAL_RETRY_SECONDS=5
WORKER_REFRESH_URL=
WORKER_REFRESH_TOKEN=
REQUIRE_RESOLVABLE_TUNNEL_HOST=false
LOG_DIR=/var/log/work-time

# Named Tunnel 모드(Quick Tunnel 429가 지속될 때 권장)
# CLOUDFLARED_TUNNEL_TOKEN과 STATIC_TUNNEL_URL을 같이 설정하면 Quick Tunnel 발급을 건너뜁니다.
CLOUDFLARED_TUNNEL_TOKEN=
STATIC_TUNNEL_URL=

# true면 KV 업데이트 없이 터널만 실행(디버깅용)
SKIP_KV_UPDATE=false
